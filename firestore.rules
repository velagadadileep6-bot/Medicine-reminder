rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read/write access to support client-side email/password authentication and state syncing
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /states/{userId} {
      allow read, write: if true;
    }
  }
}
